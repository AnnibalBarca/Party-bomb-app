{
  "expo": {
    "name": "Bomb Party",
    "slug": "party-bomb",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f0f1a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.yourname.partybomb"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f0f1a"
      },
      "package": "com.yourname.partybomb"
    },
    "scheme": "partybomb",
    "plugins": [
      "expo-router",
      ["expo-sqlite", { "enableFTS": true }],
      ["expo-asset", { "assets": ["./assets/french-words.txt"] }]
    ]
  }
}
